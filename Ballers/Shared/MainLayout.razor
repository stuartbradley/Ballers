@using Ballers.Auth
@using Ballers.Client.Auth
@using Microsoft.AspNetCore.Components.Authorization

@inherits LayoutComponentBase

<header class="main-header">
    <div class="header-inner">

        <div class="logo-area">
            <div class="logo"><span class="logo-crest"></span><span class="logo-text">Ballers</span></div>
            <AuthorizeView Context="auth">
                <Authorized>
                    <span class="hello-text">Hello @teamName</span>
                </Authorized>
            </AuthorizeView>
        </div>

        <!-- Desktop nav -->
        <nav class="nav-links">
            <NavLink href="/" Match="NavLinkMatch.All">Home</NavLink>
            <NavLink href="/fixtures">Fixtures</NavLink>
            <NavLink href="/teams">Teams</NavLink>
            <NavLink href="/stats">Stats</NavLink>
            <AuthorizeView>
                <Authorized>
                    <NavLink href="/dashboard">Dashboard</NavLink>
                    <a class="logout-link" @onclick="Logout" @onclick:preventDefault>Logout</a>
                </Authorized>
                <NotAuthorized>
                    <NavLink href="/login">Login</NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </nav>

        <!-- Hamburger (mobile only) -->
        <button class="hamburger @(navOpen ? "open" : "")"
                @onclick="ToggleNav"
                aria-label="Toggle navigation">
            <span></span>
            <span></span>
            <span></span>
        </button>

    </div>
</header>

<!-- Mobile right-slide drawer -->
<div class="nav-backdrop @(navOpen ? "is-visible" : "")" @onclick="CloseNav"></div>
<div class="mobile-overlay @(navOpen ? "is-open" : "")">
    <div class="mobile-panel-header">
        <span class="mobile-panel-logo">Ballers</span>
        <button class="mobile-panel-close" @onclick="CloseNav" aria-label="Close menu">&#x2715;</button>
    </div>
    <AuthorizeView>
        <Authorized>
            <p class="mobile-greeting">Hello, @teamName</p>
        </Authorized>
    </AuthorizeView>

    <nav class="mobile-nav">
        <NavLink href="/" Match="NavLinkMatch.All" @onclick="CloseNav">Home</NavLink>
        <NavLink href="/fixtures" @onclick="CloseNav">Fixtures</NavLink>
        <NavLink href="/teams" @onclick="CloseNav">Teams</NavLink>
        <NavLink href="/stats" @onclick="CloseNav">Stats</NavLink>
        <AuthorizeView>
            <Authorized>
                <NavLink href="/dashboard" @onclick="CloseNav">Dashboard</NavLink>
                <button class="mobile-logout-btn" @onclick="Logout">Logout</button>
            </Authorized>
            <NotAuthorized>
                <NavLink href="/login" @onclick="CloseNav">Login</NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

<div class="main-content">
    @Body
</div>

@inject AuthService Auth
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider
@code {

    private string? teamName;
    private bool navOpen = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
            teamName = user.FindFirst("TeamName")?.Value;

        StateHasChanged();
    }

    private void ToggleNav() => navOpen = !navOpen;
    private void CloseNav() => navOpen = false;

    async Task Logout()
    {
        await Auth.Logout();
        ((AuthStateProvider)AuthProvider).NotifyUserLogout();
        navOpen = false;
        Nav.NavigateTo("/");
        StateHasChanged();
    }
}
