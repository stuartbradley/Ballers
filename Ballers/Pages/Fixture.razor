@page "/fixture/{Id:int}"
@using Ballers.Client.Auth
@using Ballers.Models
@using Ballers.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@inject FixtureService FixtureService
@inject AuthService AuthService
@inject PenaltyService PenaltyService
@inject FairplayService FairplayService
@inject RefereeService RefereeService
@inject NavigationManager Nav

<PageTitle>@(fixture != null ? $"{fixture.HomeTeam} vs {fixture.AwayTeam}" : "Fixture")</PageTitle>

<div class="toast-container">
    @if (toastVisible)
    {
        <div class="toast @(toastSuccess ? "toast-success" : "toast-error")">
            @toastMessage
        </div>
    }
</div>

<div class="fixture-page">

    @if (isLoading)
    {
        <LoadingSpinner />
    }
    else if (fixture == null)
    {
        <div class="not-found-container">
            <div class="not-found-code">404</div>
            <p class="not-found-title">Fixture not found</p>
            <NavLink class="not-found-btn" href="/manager-fixtures">Back to Fixtures</NavLink>
        </div>
    }
    else
    {
        <div class="fixture-card">

            <!-- MATCH HEADER -->
            <div class="fixture-header">
                <div class="fixture-teams">
                    <span class="team">@fixture.HomeTeam</span>

                    <span class="score">
                        @if (previewHomeScore > 0 || previewAwayScore > 0)
                        {
                            <span>@previewHomeScore</span>
                            <span class="dash">-</span>
                            <span>@previewAwayScore</span>
                        }
                        else
                        {
                            <span class="vs">vs</span>
                        }
                    </span>

                    <span class="team away">@fixture.AwayTeam</span>
                </div>
            </div>

            @if (fixture.IsEditLocked)
            {
                <div class="fixture-locked-banner">
                    This fixture is locked — editing closed 2 weeks after the final whistle.
                </div>
            }

            <!-- TABS -->
            <div class="fixture-tabs">
                <button class="tab @(activeTab == "overview" ? "active" : "")"
                        @onclick="@(() => SelectTab("overview"))">
                    Overview
                </button>
                <button class="tab @(activeTab == "squad" ? "active" : "")"
                        @onclick="@(() => SelectTab("squad"))">
                    Squad
                </button>
                <button class="tab @(activeTab == "stats" ? "active" : "") @(squadSelected ? "" : "disabled")"
                        disabled="@(!squadSelected)"
                        @onclick="@(() => SelectTab("stats"))">
                    Stats
                </button>
                <button class="tab @(activeTab == "penalties" ? "active" : "")"
                        @onclick="@(() => SelectTab("penalties"))">
                    Penalties
                </button>
            </div>

            <!-- OVERVIEW TAB -->
            @if (activeTab == "overview")
            {
                <div class="tab-content">

                    @if (isAdmin)
                    {
                        @if (fixture.HomeCaptainName != null || fixture.AwayCaptainName != null)
                        {
                            <div class="captaincy-bar">
                                @if (fixture.HomeCaptainName != null)
                                {
                                    <span class="captaincy-chip"><span class="cap-badge">C</span>@fixture.HomeTeam: @fixture.HomeCaptainName</span>
                                }
                                @if (fixture.HomeViceCaptainName != null)
                                {
                                    <span class="captaincy-chip vc"><span class="cap-badge">VC</span>@fixture.HomeViceCaptainName</span>
                                }
                                @if (fixture.AwayCaptainName != null)
                                {
                                    <span class="captaincy-chip"><span class="cap-badge">C</span>@fixture.AwayTeam: @fixture.AwayCaptainName</span>
                                }
                                @if (fixture.AwayViceCaptainName != null)
                                {
                                    <span class="captaincy-chip vc"><span class="cap-badge">VC</span>@fixture.AwayViceCaptainName</span>
                                }
                            </div>
                        }
                    }
                    else if (!string.IsNullOrEmpty(myCaptainName) || !string.IsNullOrEmpty(myViceName))
                    {
                        <div class="captaincy-bar">
                            @if (!string.IsNullOrEmpty(myCaptainName))
                            {
                                <span class="captaincy-chip"><span class="cap-badge">C</span>@myCaptainName</span>
                            }
                            @if (!string.IsNullOrEmpty(myViceName))
                            {
                                <span class="captaincy-chip vc"><span class="cap-badge">VC</span>@myViceName</span>
                            }
                        </div>
                    }

                    <div class="fixture-info-grid">
                        <div class="info-card">
                            <span class="label">Status</span>
                            @if (fixture.IsPlayed)
                            {
                                <span class="status played">Played</span>
                            }
                            else if (fixture.Kickoff != null)
                            {
                                <span class="status scheduled">Scheduled</span>
                            }
                            else
                            {
                                <span class="status awaiting">Awaiting</span>
                            }
                        </div>
                        <div class="info-card">
                            <span class="label">Location</span>
                            <span class="info-value">
                                @if (!string.IsNullOrEmpty(fixture.Location))
                                {
                                    @fixture.Location
                                    @if (!string.IsNullOrEmpty(fixture.Postcode))
                                    {
                                        <span class="info-postcode">, @fixture.Postcode</span>
                                    }
                                }
                                else
                                {
                                    @("Not set")
                                }
                            </span>
                        </div>
                        <div class="info-card">
                            <span class="label">Kickoff</span>
                            <span class="info-value">@(fixture.Kickoff?.ToString("dd MMM HH:mm") ?? "Not set")</span>
                        </div>
                        <div class="info-card">
                            <span class="label">Referee</span>
                            <span class="info-value">@(fixture.RefereeName ?? "Not assigned")</span>
                        </div>
                    </div>

                    @if (headToHead.Any())
                    {
                        <div class="h2h-section">
                            <h3>Recent Meetings</h3>
                            @foreach (var m in headToHead)
                            {
                                var date = (m.Kickoff ?? m.WindowEnd).ToString("dd MMM yy");
                                var homeWin = m.HomeScore > m.AwayScore;
                                var awayWin = m.AwayScore > m.HomeScore;
                                <div class="h2h-row">
                                    <span class="h2h-team @(homeWin ? "winner" : "")">@m.HomeTeam</span>
                                    <span class="h2h-score">@m.HomeScore – @m.AwayScore</span>
                                    <span class="h2h-team away @(awayWin ? "winner" : "")">@m.AwayTeam</span>
                                    <span class="h2h-date">@date</span>
                                </div>
                            }
                        </div>
                    }

                    @if (isAdmin)
                    {
                        <div class="schedule-section">
                            <h3>Schedule</h3>
                            <div class="schedule-editor">
                                <div class="schedule-field">
                                    <label>Location</label>
                                    <input type="text" class="stat-input schedule-input" placeholder="Venue name" @bind="scheduleLocation" disabled="@fixture.IsEditLocked" />
                                </div>
                                <div class="schedule-field">
                                    <label>Postcode</label>
                                    <input type="text" class="stat-input schedule-input" placeholder="e.g. M1 1AE" @bind="schedulePostcode" disabled="@fixture.IsEditLocked" />
                                </div>
                                <div class="schedule-field">
                                    <label>Kickoff</label>
                                    <input type="datetime-local" class="stat-input schedule-input" @bind="scheduleKickoff" disabled="@fixture.IsEditLocked" />
                                </div>
                                <button class="primary-btn" @onclick="SaveSchedule" disabled="@fixture.IsEditLocked">Save Schedule</button>
                            </div>
                        </div>

                        <div class="referee-section">
                            <h3>Referee</h3>
                            @if (!allReferees.Any())
                            {
                                <p class="referee-none">No referees registered yet. <a href="/referees">Add one →</a></p>
                            }
                            else
                            {
                                <div class="referee-editor">
                                    <select class="referee-select" @bind="selectedRefereeId" disabled="@fixture.IsEditLocked">
                                        <option value="">— No referee assigned —</option>
                                        @foreach (var r in allReferees)
                                        {
                                            var booked = r.UpcomingFixtures.Any(f =>
                                                f.FixtureId != fixture.Id &&
                                                f.WindowStart <= fixture.WindowEnd &&
                                                f.WindowEnd   >= fixture.WindowStart);
                                            <option value="@r.Id">
                                                @r.Name@(booked ? " (Booked this window)" : "")
                                            </option>
                                        }
                                    </select>
                                    <button class="primary-btn" @onclick="SaveReferee" disabled="@fixture.IsEditLocked">Save</button>
                                </div>
                                @if (selectedRefereeId.HasValue)
                                {
                                    var current = allReferees.FirstOrDefault(r => r.Id == selectedRefereeId);
                                    @if (current != null)
                                    {
                                        <div class="referee-contact">
                                            @if (!string.IsNullOrEmpty(current.PhoneNumber))
                                            {
                                                <a href="tel:@current.PhoneNumber" class="referee-contact-link">📞 @current.PhoneNumber</a>
                                            }
                                            @if (!string.IsNullOrEmpty(current.Email))
                                            {
                                                <a href="mailto:@current.Email" class="referee-contact-link">✉ @current.Email</a>
                                            }
                                        </div>
                                    }
                                }
                            }
                        </div>

                        <div class="fairplay-section">
                            <h3>Fairplay Ratings</h3>
                            <div class="fairplay-editor">
                                <div class="fairplay-team">
                                    <label>@fixture.HomeTeam</label>
                                    <input type="number" class="stat-input" min="1" max="10" @bind="fairplayHomeRating" disabled="@fixture.IsEditLocked" />
                                </div>
                                <div class="fairplay-team">
                                    <label>@fixture.AwayTeam</label>
                                    <input type="number" class="stat-input" min="1" max="10" @bind="fairplayAwayRating" disabled="@fixture.IsEditLocked" />
                                </div>
                                <button class="primary-btn" @onclick="SaveFairplay" disabled="@fixture.IsEditLocked">Save Ratings</button>
                            </div>
                        </div>
                    }

                </div>
            }

            <!-- SQUAD TAB -->
            @if (activeTab == "squad")
            {
                <div class="tab-content">
                    <h3>Select Match Squad</h3>

                    @foreach (var player in teamPlayers)
                    {
                        <label class="squad-row">
                            <input type="checkbox" @bind="player.IsSelected" disabled="@fixture.IsEditLocked" />
                            <span class="squad-name">@player.Name</span>
                            @if (player.IsSelected && !fixture.IsEditLocked)
                            {
                                <button class="cap-toggle @(captainPlayerId == player.PlayerId ? "active" : "")"
                                        @onclick="() => SetCaptain(player.PlayerId)"
                                        @onclick:stopPropagation>C</button>
                                <button class="cap-toggle vc @(vicePlayerId == player.PlayerId ? "active" : "")"
                                        @onclick="() => SetVice(player.PlayerId)"
                                        @onclick:stopPropagation>VC</button>
                            }
                        </label>
                    }

                    <div class="squad-actions">
                        <button class="primary-btn squad-save-btn" @onclick="SaveSquad" disabled="@fixture.IsEditLocked">Save Squad</button>
                        @if (!fixture.IsEditLocked)
                        {
                            <button class="primary-btn squad-save-btn captaincy-save-btn" @onclick="SaveCaptaincy">Save Captaincy</button>
                        }
                    </div>
                </div>
            }

            <!-- MATCH STATS TAB -->
            @if (activeTab == "stats")
            {
                <div class="tab-content">
                    <h3>Match Stats</h3>

                    <div class="stats-team-toggle">
                        <button class="stats-team-btn @(!viewingOpponent ? "active" : "")"
                                @onclick="() => viewingOpponent = false">@myTeamLabel</button>
                        <button class="stats-team-btn @(viewingOpponent ? "active" : "")"
                                @onclick="LoadOpponentStats">@opponentTeamName</button>
                    </div>

                    @if (!viewingOpponent)
                    {
                        <div class="stats-table">
                            <div class="stats-header">
                                <span>Player</span>
                                <span>Goals</span>
                                <span>Assists</span>
                                <span>MOTM</span>
                                <span>Yellow</span>
                                <span>Red</span>
                            </div>

                            @foreach (var player in players)
                            {
                                <div class="stats-row">
                                    <span class="player-name">@player.Name</span>
                                    <input type="number" min="0" class="stat-input" @bind="player.Goals" disabled="@fixture.IsEditLocked" />
                                    <input type="number" min="0" class="stat-input" @bind="player.Assists" disabled="@fixture.IsEditLocked" />
                                    <input type="checkbox" class="motm-checkbox" checked="@player.IsMotm" @onchange="@(() => SelectMotm(player))" disabled="@fixture.IsEditLocked" />
                                    <input type="checkbox" class="motm-checkbox yellow-card" @bind="player.HasYellowCard" disabled="@fixture.IsEditLocked" />
                                    <input type="checkbox" class="motm-checkbox red-card" @bind="player.HasRedCard" disabled="@fixture.IsEditLocked" />
                                </div>
                            }
                        </div>

                        <button class="submit-stats-btn" @onclick="SubmitStats" disabled="@fixture.IsEditLocked">Submit Match Stats</button>
                    }
                    else
                    {
                        @if (opponentStats.Any())
                        {
                            <div class="stats-table">
                                <div class="stats-header">
                                    <span>Player</span>
                                    <span>Goals</span>
                                    <span>Assists</span>
                                    <span>MOTM</span>
                                    <span>Yellow</span>
                                    <span>Red</span>
                                </div>
                                @foreach (var p in opponentStats)
                                {
                                    <div class="stats-row">
                                        <span class="player-name">@p.Name</span>
                                        <span class="stat-value">@p.Goals</span>
                                        <span class="stat-value">@p.Assists</span>
                                        <span class="stat-value"><span class="motm-dot @(p.IsMotm ? "on" : "")"></span></span>
                                        <span class="stat-value"><span class="card-dot yellow @(p.YellowCard ? "on" : "")"></span></span>
                                        <span class="stat-value"><span class="card-dot red @(p.RedCard ? "on" : "")"></span></span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="stats-pending">@opponentTeamName have not submitted their stats yet.</p>
                        }
                    }
                </div>
            }

            <!-- PENALTIES TAB -->
            @if (activeTab == "penalties")
            {
                <div class="tab-content">
                    @if (!fixture.IsPlayed)
                    {
                        <div class="penalty-unavailable">
                            Penalty kicks can be entered once the match has been played.
                        </div>
                    }
                    else
                    {
                        <h3>My Team's Penalties</h3>

                        <div class="penalty-table">
                            <div class="penalty-header">
                                <span>#</span>
                                <span>Player</span>
                                <span>Result</span>
                            </div>

                            @foreach (var kick in penaltyKicks)
                            {
                                <div class="penalty-row">
                                    <span class="kick-order">@kick.Order</span>
                                    <select class="penalty-select" @bind="kick.PlayerId" disabled="@fixture.IsEditLocked">
                                        <option value="0">Select player…</option>
                                        @foreach (var p in teamPlayers)
                                        {
                                            <option value="@p.PlayerId">@p.Name</option>
                                        }
                                    </select>
                                    <label class="scored-toggle">
                                        <input type="checkbox" @bind="kick.Scored" disabled="@fixture.IsEditLocked" />
                                        <span>@(kick.Scored ? "Scored" : "Missed")</span>
                                    </label>
                                </div>
                            }
                        </div>

                        <button class="submit-stats-btn" @onclick="SubmitPenalties" disabled="@fixture.IsEditLocked">Submit Penalties</button>

                        @if (opponentKicks.Any())
                        {
                            <div class="opponent-kicks">
                                <h3>@(isUserHome ? fixture.AwayTeam : fixture.HomeTeam)'s Penalties</h3>
                                <div class="penalty-table">
                                    <div class="penalty-header">
                                        <span>#</span>
                                        <span>Player</span>
                                        <span>Result</span>
                                    </div>
                                    @foreach (var kick in opponentKicks)
                                    {
                                        <div class="penalty-row">
                                            <span class="kick-order">@kick.Order</span>
                                            <span class="kick-player">@kick.PlayerName</span>
                                            <span class="kick-result @(kick.Scored ? "scored" : "missed")">
                                                @(kick.Scored ? "Scored" : "Missed")
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="opponent-pending">Opponent has not yet submitted their penalties.</div>
                        }
                    }
                </div>
            }

        </div>
    }

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private FixtureDetailsDto fixture;

    private bool isLoading = true;
    private string activeTab = "overview";
    private bool squadSelected = false;

    private List<TeamPlayerViewModel> teamPlayers = new();
    private List<PlayerStatViewModel> players = new();

    private int previewHomeScore = 0;
    private int previewAwayScore = 0;
    private int opponentSavedScore = 0;
    private bool isUserHome = false;
    private List<PenaltyKickViewModel> penaltyKicks = new();
    private List<PenaltyKickResultDto> opponentKicks = new();

    private bool isAdmin = false;
    private int fairplayHomeRating = 5;
    private int fairplayAwayRating = 5;

    private bool viewingOpponent = false;
    private List<OpponentPlayerStatDto> opponentStats = new();
    private bool opponentStatsLoaded = false;
    private string myTeamLabel => isAdmin ? fixture!.HomeTeam : "My Team";
    private string opponentTeamName => isAdmin ? fixture!.AwayTeam : (isUserHome ? fixture!.AwayTeam : fixture!.HomeTeam);

    private List<HeadToHeadResultDto> headToHead = new();
    private bool h2hLoaded = false;

    private int? captainPlayerId;
    private int? vicePlayerId;
    private string? myCaptainName => isUserHome ? fixture?.HomeCaptainName : fixture?.AwayCaptainName;
    private string? myViceName    => isUserHome ? fixture?.HomeViceCaptainName : fixture?.AwayViceCaptainName;

    private string scheduleLocation = "";
    private string? schedulePostcode;
    private DateTime scheduleKickoff = DateTime.Now;

    private List<RefereeDto> allReferees = new();
    private int? selectedRefereeId;

    private bool toastVisible = false;
    private bool toastSuccess = true;
    private string toastMessage = "";

    async Task ShowToast(string message, bool success = true)
    {
        toastMessage = message;
        toastSuccess = success;
        toastVisible = true;
        StateHasChanged();
        await Task.Delay(3000);
        toastVisible = false;
        StateHasChanged();
    }

    class PenaltyKickViewModel
    {
        public int Order { get; set; }
        public int PlayerId { get; set; }
        public bool Scored { get; set; }
    }

    class PlayerStatViewModel
    {
        public int TeamId { get; set; }
        public int PlayerId { get; set; }
        public string Name { get; set; } = "";
        private int goals;
        public int Goals
        {
            get => goals;
            set { goals = value; OnGoalsChanged?.Invoke(); }
        }
        public Action? OnGoalsChanged;
        public int Assists { get; set; }
        public bool IsMotm { get; set; }
        public bool HasYellowCard { get; set; }
        public bool HasRedCard { get; set; }
    }

    class TeamPlayerViewModel
    {
        public int PlayerId { get; set; }
        public string Name { get; set; } = "";
        public bool IsSelected { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadFixture();
        await LoadHeadToHead();
    }

    async Task LoadFixture()
    {
        fixture = await FixtureService.GetFixture(Id);
        isLoading = false;

        if (fixture == null) return;

        var savedStats = await FixtureService.GetFixtureStats(fixture.Id);
        var user = await AuthService.GetCurrentUser();

        isUserHome = user?.TeamId == fixture.HomeTeamId;
        isAdmin = user?.IsAdmin ?? false;
        opponentSavedScore = isUserHome ? fixture.AwayScore : fixture.HomeScore;

        int teamId = isUserHome ? fixture.HomeTeamId : fixture.AwayTeamId;

        var squadTask = FixtureService.GetFixtureSquad(fixture.Id);
        var myPlayersTask = FixtureService.GetFixturePlayers(fixture.Id);
        await Task.WhenAll(squadTask, myPlayersTask);

        var squadIds = squadTask.Result.Select(p => p.PlayerId).ToHashSet();
        teamPlayers = myPlayersTask.Result.Select(p => new TeamPlayerViewModel
        {
            PlayerId = p.Id,
            Name = p.Name,
            IsSelected = squadIds.Contains(p.Id)
        }).ToList();

        squadSelected = teamPlayers.Count(p => p.IsSelected) > 10;

        players = teamPlayers
            .Where(p => p.IsSelected)
            .Select(p =>
            {
                var stat = savedStats.FirstOrDefault(x => x.PlayerId == p.PlayerId);
                return new PlayerStatViewModel
                {
                    PlayerId = p.PlayerId,
                    Name = p.Name,
                    TeamId = teamId,
                    Goals = stat?.Goals ?? 0,
                    Assists = stat?.Assists ?? 0,
                    IsMotm = stat?.IsManOfTheMatch ?? false,
                    HasYellowCard = stat?.HadYellowCard ?? false,
                    HasRedCard = stat?.HadRedCard ?? false
                };
            }).ToList();

        previewHomeScore = fixture.HomeScore;
        previewAwayScore = fixture.AwayScore;

        foreach (var p in players)
            p.OnGoalsChanged = UpdateScorePreview;

        var shootout = await PenaltyService.GetShootout(fixture.Id);
        var myKicks = isUserHome ? shootout?.HomeKicks : shootout?.AwayKicks;
        opponentKicks = (isUserHome ? shootout?.AwayKicks : shootout?.HomeKicks) ?? new();

        penaltyKicks = Enumerable.Range(1, 5).Select(i =>
        {
            var existing = myKicks?.FirstOrDefault(k => k.Order == i);
            return new PenaltyKickViewModel
            {
                Order = i,
                PlayerId = existing?.PlayerId ?? 0,
                Scored = existing?.Scored ?? false
            };
        }).ToList();

        captainPlayerId = (isAdmin || isUserHome) ? fixture.HomeCaptainId : fixture.AwayCaptainId;
        vicePlayerId    = (isAdmin || isUserHome) ? fixture.HomeViceCaptainId : fixture.AwayViceCaptainId;

        if (isAdmin)
        {
            scheduleLocation = fixture.Location ?? "";
            schedulePostcode = fixture.Postcode;
            scheduleKickoff = fixture.Kickoff ?? DateTime.Now;

            var fairplay = await FairplayService.GetRatings(fixture.Id);
            fairplayHomeRating = fairplay?.HomeRating ?? 5;
            fairplayAwayRating = fairplay?.AwayRating ?? 5;

            allReferees = await RefereeService.GetAll();
            selectedRefereeId = fixture.RefereeId;
        }
    }

    async Task LoadHeadToHead()
    {
        if (!h2hLoaded)
        {
            headToHead = await FixtureService.GetHeadToHead(fixture!.Id);
            h2hLoaded = true;
        }
    }

    async Task SaveReferee()
    {
        await RefereeService.AssignToFixture(fixture!.Id, selectedRefereeId);
        fixture = await FixtureService.GetFixture(fixture!.Id);
        await ShowToast("Referee saved.");
    }

    async Task SaveSchedule()
    {
        await FixtureService.UpdateFixtureSchedule(fixture!.Id, scheduleLocation, schedulePostcode, scheduleKickoff);
        fixture = await FixtureService.GetFixture(fixture!.Id);
        await ShowToast("Schedule saved.");
    }


    async Task SaveFairplay()
    {
        if (fairplayHomeRating < 1 || fairplayHomeRating > 10 ||
            fairplayAwayRating < 1 || fairplayAwayRating > 10)
        {
            await ShowToast("Ratings must be between 1 and 10.", success: false);
            return;
        }
        await FairplayService.SubmitRatings(fixture!.Id, fairplayHomeRating, fairplayAwayRating);
        await ShowToast("Fairplay ratings saved.");
    }

    void UpdateScorePreview()
    {
        var myGoals = players.Sum(x => x.Goals);
        if (isUserHome) { previewHomeScore = myGoals; previewAwayScore = opponentSavedScore; }
        else             { previewHomeScore = opponentSavedScore; previewAwayScore = myGoals; }
        StateHasChanged();
    }

    async Task LoadOpponentStats()
    {
        if (!opponentStatsLoaded)
        {
            int? overrideTeamId = isAdmin ? fixture!.AwayTeamId : null;
            opponentStats = await FixtureService.GetOpponentStats(fixture!.Id, overrideTeamId);
            opponentStatsLoaded = true;
        }
        viewingOpponent = true;
    }

    async Task SelectTab(string tab)
    {
        activeTab = tab;
        viewingOpponent = false;
        if (tab == "overview") await LoadHeadToHead();
    }

    void SetCaptain(int playerId)
    {
        captainPlayerId = captainPlayerId == playerId ? null : playerId;
        if (captainPlayerId.HasValue && vicePlayerId == captainPlayerId) vicePlayerId = null;
    }

    void SetVice(int playerId)
    {
        vicePlayerId = vicePlayerId == playerId ? null : playerId;
        if (vicePlayerId.HasValue && captainPlayerId == vicePlayerId) captainPlayerId = null;
    }

    async Task SaveCaptaincy()
    {
        await FixtureService.SaveCaptaincy(fixture!.Id, captainPlayerId, vicePlayerId);
        fixture = await FixtureService.GetFixture(fixture!.Id);
        await ShowToast("Captaincy saved.");
    }

    void SelectMotm(PlayerStatViewModel selected)
    {
        bool wasSelected = selected.IsMotm;
        foreach (var p in players) p.IsMotm = false;
        if (!wasSelected) selected.IsMotm = true;
    }

    async Task SaveSquad()
    {
        var selectedPlayers = teamPlayers.Where(p => p.IsSelected).Select(p => p.PlayerId).ToList();
        await FixtureService.SaveSquad(fixture!.Id, selectedPlayers);

        squadSelected = selectedPlayers.Count > 10;

        int teamId = isUserHome ? fixture!.HomeTeamId : fixture!.AwayTeamId;
        var savedStats = await FixtureService.GetFixtureStats(fixture!.Id);

        players = teamPlayers
            .Where(p => p.IsSelected)
            .Select(p =>
            {
                var stat = savedStats.FirstOrDefault(x => x.PlayerId == p.PlayerId);
                return new PlayerStatViewModel
                {
                    PlayerId = p.PlayerId,
                    Name = p.Name,
                    TeamId = teamId,
                    Goals = stat?.Goals ?? 0,
                    Assists = stat?.Assists ?? 0,
                    IsMotm = stat?.IsManOfTheMatch ?? false,
                    HasYellowCard = stat?.HadYellowCard ?? false,
                    HasRedCard = stat?.HadRedCard ?? false
                };
            }).ToList();

        foreach (var p in players)
            p.OnGoalsChanged = UpdateScorePreview;

        await ShowToast("Squad saved.");
    }

    async Task SubmitPenalties()
    {
        var kicks = penaltyKicks
            .Where(k => k.PlayerId > 0)
            .Select(k => new PenaltyKickInput { PlayerId = k.PlayerId, Order = k.Order, Scored = k.Scored })
            .ToList();

        if (kicks.Count != 5)
        {
            await ShowToast("Please assign a player to all 5 kicks.", success: false);
            return;
        }

        await PenaltyService.SubmitKicks(fixture!.Id, kicks);
        await LoadFixture();
        await ShowToast("Penalties submitted.");
    }

    async Task SubmitStats()
    {
        if (!players.Any(p => p.IsMotm))
        {
            await ShowToast("Please select a Man of the Match.", success: false);
            return;
        }

        if (players.Any(p => p.Goals < 0 || p.Assists < 0))
        {
            await ShowToast("Goals and assists cannot be negative.", success: false);
            return;
        }

        var stats = players.Select(p => new FixturePlayerStatInput
        {
            PlayerId = p.PlayerId,
            Goals = p.Goals,
            Assists = p.Assists,
            IsManOfTheMatch = p.IsMotm,
            HadYellowCard = p.HasYellowCard,
            HadRedCard = p.HasRedCard
        }).ToList();

        await FixtureService.SubmitStats(fixture!.Id, stats);
        await LoadFixture();
        await ShowToast("Match stats saved.");
    }
}
