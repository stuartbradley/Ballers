@page "/admin/fairplay"
@using Ballers.Models
@using Ballers.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

@inject FairplayService FairplayService
@inject SeasonService SeasonService

<PageTitle>Fairplay Table</PageTitle>

<div class="fairplay-page">

    <div class="fairplay-hero">
        <div class="fairplay-hero-inner">
            <div class="hero-top">
                <p class="fairplay-eyebrow">Admin</p>
                <a href="/admin" class="back-link">← Back to Admin</a>
            </div>
            <h1>Fairplay Table</h1>
        </div>
    </div>

    <div class="fairplay-body">

        @if (isLoading)
        {
            <LoadingSpinner />
        }
        else
        {
            <div class="season-bar">
                <span class="season-label">Season</span>
                <div class="select-wrapper">
                    <select class="season-select"
                            @bind="selectedSeasonId"
                            @bind:after="LoadTable">
                        @foreach (var s in seasons)
                        {
                            <option value="@s.Id">Season @s.SeasonNumber</option>
                        }
                    </select>
                </div>
            </div>

            <div class="fairplay-card">
                <table class="fairplay-table">
                    <thead>
                        <tr>
                            <th class="col-pos">#</th>
                            <th>Team</th>
                            <th class="col-num">Rated</th>
                            <th class="col-num">Total</th>
                            <th class="col-avg">Avg</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!rows.Any())
                        {
                            <tr>
                                <td colspan="5" class="empty-row">No ratings recorded yet.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var row in rows)
                            {
                                <tr>
                                    <td class="pos">@row.Position</td>
                                    <td class="team-name">@row.Team</td>
                                    <td class="col-num muted">@row.Rated</td>
                                    <td class="col-num muted">@row.TotalRating</td>
                                    <td class="col-avg">
                                        <span class="avg @RatingClass(row.AverageRating)">
                                            @row.AverageRating.ToString("0.00")
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>

</div>

@code {
    private bool isLoading = true;
    private List<SeasonDto> seasons = new();
    private int selectedSeasonId;
    private List<FairplayTableRowDto> rows = new();

    protected override async Task OnInitializedAsync()
    {
        seasons = await SeasonService.GetSeasons();
        var current = await SeasonService.GetCurrentSeason();
        selectedSeasonId = current?.Id ?? seasons.FirstOrDefault()?.Id ?? 0;
        await LoadTable();
        isLoading = false;
    }

    async Task LoadTable()
    {
        if (selectedSeasonId > 0)
            rows = await FairplayService.GetTable(selectedSeasonId);
    }

    string RatingClass(double avg) => avg >= 7 ? "high" : avg >= 5 ? "mid" : "low";
}
