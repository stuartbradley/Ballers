@page "/dashboard"
@attribute [Authorize]

@using Ballers.Models
@using Ballers.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthProvider
@inject StatService StatService
@inject IJSRuntime JS
<PageTitle>Dashboard</PageTitle>

<div class="dashboard-container">

    <AuthorizeView Context="auth">

        <Authorized>

            @if (isLoading)
            {
                <LoadingSpinner />
            }
            else
            {
                <div class="dashboard-hero">
                    <div class="dashboard-hero-inner">

                        <div class="dash-greeting-block">
                            <p class="dash-eyebrow">Manager Dashboard</p>
                            <h1 class="dash-greeting">
                                Welcome back,
                                <span class="dash-team">@(auth.User.FindFirst("TeamName")?.Value ?? "Manager")</span>
                            </h1>
                        </div>

                        @if (stats != null)
                        {
                            <div class="dash-record">
                                <div class="dash-stat-box dash-win">
                                    <span class="dash-stat-num">@stats.Wins</span>
                                    <span class="dash-stat-lbl">Wins</span>
                                </div>
                                <div class="dash-sep"></div>
                                <div class="dash-stat-box dash-draw">
                                    <span class="dash-stat-num">@stats.Draws</span>
                                    <span class="dash-stat-lbl">Draws</span>
                                </div>
                                <div class="dash-sep"></div>
                                <div class="dash-stat-box dash-loss">
                                    <span class="dash-stat-num">@stats.Losses</span>
                                    <span class="dash-stat-lbl">Losses</span>
                                </div>
                            </div>
                        }

                    </div>
                </div>

                <div class="dashboard-grid">

                    <!-- Season chart + player stats -->
                    <div class="dashboard-card chart-card">
                        <h3>Season Record</h3>
                        <div class="stats-layout">

                            <div class="chart-col">
                                <div class="chart-wrapper">
                                    <canvas id="winLossChart" style="@(chartReady ? "" : "visibility:hidden")"></canvas>
                                    @if (!chartReady)
                                    {
                                        <div class="chart-spinner-overlay">
                                            <LoadingSpinner />
                                        </div>
                                    }
                                </div>
                                <div class="chart-legend">
                                    <span class="legend-item"><span class="legend-dot win-dot"></span>Wins</span>
                                    <span class="legend-item"><span class="legend-dot draw-dot"></span>Draws</span>
                                    <span class="legend-item"><span class="legend-dot loss-dot"></span>Losses</span>
                                </div>
                            </div>

                            <div class="mini-stats">
                                <div class="mini-card goals-mini">
                                    <span class="mini-title">Top Goalscorer</span>
                                    @if (topScorer != null)
                                    {
                                        <span class="mini-name">@topScorer.Name</span>
                                        <span class="mini-value">@topScorer.Goals Goals</span>
                                    }
                                    else
                                    {
                                        <span class="mini-name">—</span>
                                        <span class="mini-value">No data yet</span>
                                    }
                                </div>
                                <div class="mini-card assists-mini">
                                    <span class="mini-title">Top Assists</span>
                                    @if (topAssist != null)
                                    {
                                        <span class="mini-name">@topAssist.Name</span>
                                        <span class="mini-value">@topAssist.Assists Assists</span>
                                    }
                                    else
                                    {
                                        <span class="mini-name">—</span>
                                        <span class="mini-value">No data yet</span>
                                    }
                                </div>
                                <div class="mini-card motm-mini">
                                    <span class="mini-title">Top Player</span>
                                    @if (topPlayer != null)
                                    {
                                        <span class="mini-name">@topPlayer.Name</span>
                                        <span class="mini-value">@topPlayer.Motm MOTMs</span>
                                    }
                                    else
                                    {
                                        <span class="mini-name">—</span>
                                        <span class="mini-value">No data yet</span>
                                    }
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- Quick action tiles -->
                    <div class="action-tiles-row">

                        <NavLink class="dashboard-card action-card myteam-action" href="/my-team">
                            <div class="action-body">
                                <h3>My Team</h3>
                                <p>Edit profile, crest and contact details</p>
                            </div>
                            <span class="action-arrow">›</span>
                        </NavLink>

                        <NavLink class="dashboard-card action-card fixtures-action" href="/manager-fixtures">
                            <div class="action-body">
                                <h3>Fixtures</h3>
                                <p>View and manage upcoming matches</p>
                            </div>
                            <span class="action-arrow">›</span>
                        </NavLink>

                        <NavLink class="dashboard-card action-card squad-action" href="/my-squad">
                            <div class="action-body">
                                <h3>My Squad</h3>
                                <p>Manage your team and player list</p>
                            </div>
                            <span class="action-arrow">›</span>
                        </NavLink>

                        <AuthorizeView Roles="Admin">
                            <NavLink class="dashboard-card action-card admin-action" href="/admin">
                                <div class="action-body">
                                    <h3>Admin Panel</h3>
                                    <p>Manage seasons and league setup</p>
                                </div>
                                <span class="action-arrow">›</span>
                            </NavLink>
                        </AuthorizeView>

                    </div>

                </div>
            }

        </Authorized>

    </AuthorizeView>

</div>

@code {

    private WinLossDto? stats;
    private PlayerGoalsDto? topScorer;
    private PlayerAssistDto? topAssist;
    private PlayerMotmDto? topPlayer;
    private bool isLoading = true;
    private bool chartRendered = false;
    private bool chartReady = false;

    protected override async Task OnInitializedAsync()
    {
        var scorers = await StatService.GetTopGoalScorers();
        var assists = await StatService.GetTopAssists();
        var motm = await StatService.GetTopMotm();

        topScorer = scorers.FirstOrDefault();
        topAssist = assists.FirstOrDefault();
        topPlayer = motm.FirstOrDefault();

        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (chartRendered || isLoading) return;
        chartRendered = true;

        stats = await StatService.GetWinLoss();

        if (stats != null)
        {
            await JS.InvokeVoidAsync(
                "ballersCharts.renderWinLossChart",
                "winLossChart",
                stats.Wins,
                stats.Draws,
                stats.Losses);
        }

        chartReady = true;
        StateHasChanged();
    }
}
